/var/log/nginx/*.log {
    daily
    missingok
    rotate 15
    notifempty
    copytruncate
    sharedscripts

    postrotate
        TODAY=$(date +%Y%m%d)
        TARGET="/var/log/nginx/access.log-$TODAY"
 
        if [ -f "$TARGET" ]; then
            anonip --input "$TARGET" | sed 's/call=[^&]\+/call=W1AW/' | gzip > "$TARGET.anon.gz"
        fi
    endscript
}
