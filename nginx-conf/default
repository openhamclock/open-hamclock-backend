server {
    listen 80 default_server;
    listen [::]:80 default_server;

    listen 443 ssl default_server;
    listen [::]:443 ssl default_server;

    ssl_certificate /etc/nginx/server.pem;
    ssl_certificate_key /etc/nginx/server.pem;

    # Log formats and locations
    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log warn;

    # Disable keeping connections alive if needed by HamClock (same as Lighttpd)
    keepalive_timeout 0;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.0;

        # Forward headers for proxy identification
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Disable buffering for CGI responsiveness
        proxy_buffering off;

        # Match VOACAP timeouts (up to 300s)
        proxy_read_timeout 300s;
        proxy_send_timeout 360s;
    }
}
